---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} | DCO 550</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&family=Rajdhani:wght@500;700&family=Share+Tech+Mono&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style is:global>
        :root {
            --bg-dark: #05070a;
            --bg-surface: #0a0f18;
            --bg-card: #0d1421;
            --accent-green: #00ff41; /* Phosphor Green */
            --accent-blue: #00d2ff;
            --accent-gold: #ffcc00; /* Caution Gold */
            --accent-red: #ff3e3e;
            --text-primary: #e2e8f0;
            --text-secondary: #94a3b8;
            --text-dim: #475569;
            --border: #1e293b;
            --border-bright: #334155;
            --glow-green: 0 0 10px rgba(0, 255, 65, 0.3);
        }

        * {
            box-sizing: border-box;
        }

        @keyframes scanline {
            0% { bottom: 100%; }
            100% { bottom: 0%; }
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-primary);
            font-family: 'Inter', sans-serif;
            margin: 0;
            line-height: 1.6;
            overflow-x: hidden;
        }

        body::before {
            content: "";
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background: rgba(0, 255, 65, 0.1);
            z-index: 1000;
            pointer-events: none;
            animation: scanline 8s linear infinite;
        }

        h1, h2, h3, h4 {
            font-family: 'Rajdhani', sans-serif;
            text-transform: uppercase;
            letter-spacing: 2px;
            font-weight: 700;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 0 30px;
        }

        nav {
            background-color: rgba(10, 15, 24, 0.9);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--accent-green);
            padding: 10px 0;
            position: sticky;
            top: 0;
            z-index: 100;
            box-shadow: var(--glow-green);
        }

        nav .container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            max-width: 1400px;
        }

        .logo {
            font-family: 'Share Tech Mono', monospace;
            font-size: 18px;
            color: var(--accent-green);
            text-decoration: none;
            font-weight: bold;
            display: flex;
            align-items: center;
            gap: 10px;
            white-space: nowrap;
        }

        .logo img {
            height: 28px;
        }

        .nav-links {
            display: flex;
            gap: 8px;
            margin: 0 15px;
        }

        .nav-links a {
            color: var(--text-secondary);
            text-decoration: none;
            font-size: 11px;
            font-family: 'Share Tech Mono', monospace;
            text-transform: uppercase;
            padding: 4px 6px;
            border: 1px solid transparent;
            transition: all 0.2s;
            white-space: nowrap;
        }

        .nav-links a:hover {
            color: var(--accent-green);
            border: 1px solid var(--accent-green);
            background: rgba(0, 255, 65, 0.05);
        }

        footer {
            border-top: 1px solid var(--border);
            padding: 40px 0;
            margin-top: 80px;
            background-color: var(--bg-surface);
        }

        .hero {
            padding: 120px 0;
            text-align: center;
            border-bottom: 1px solid var(--border);
            position: relative;
        }

        .hero::after {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: linear-gradient(var(--border) 1px, transparent 1px), linear-gradient(90deg, var(--border) 1px, transparent 1px);
            background-size: 40px 40px;
            opacity: 0.1;
            pointer-events: none;
        }

        .accent {
            color: var(--accent-green);
            text-shadow: var(--glow-green);
        }

        .card {
            background-color: var(--bg-card);
            border: 1px solid var(--border-bright);
            padding: 25px;
            position: relative;
            transition: border-color 0.2s;
        }

        .card:hover {
            border-color: var(--accent-green);
        }

        .card::before {
            content: "";
            position: absolute;
            top: -1px;
            left: -1px;
            width: 10px;
            height: 10px;
            border-top: 2px solid var(--accent-green);
            border-left: 2px solid var(--accent-green);
        }

        .btn {
            display: inline-block;
            background-color: transparent;
            color: var(--accent-green);
            border: 1px solid var(--accent-green);
            padding: 12px 30px;
            text-decoration: none;
            font-weight: bold;
            font-family: 'Share Tech Mono', monospace;
            text-transform: uppercase;
            transition: all 0.2s;
            cursor: pointer;
        }

        .btn:hover {
            background-color: var(--accent-green);
            color: #000;
            box-shadow: var(--glow-green);
        }

        .status-tag {
            font-family: 'Share Tech Mono', monospace;
            font-size: 12px;
            padding: 2px 8px;
            border-radius: 2px;
            text-transform: uppercase;
        }

        .status-online { background: rgba(34, 197, 94, 0.1); color: var(--accent-green); border: 1px solid var(--accent-green); }
        .status-warning { background: rgba(234, 179, 8, 0.1); color: var(--accent-gold); border: 1px solid var(--accent-gold); }
    </style>
</head>
<body>
    <nav>
        <div class="container">
            <a href="/courses/adversary-hunting/" class="logo">
                <img src="/courses/adversary-hunting/assets/mccog_logo.png" alt="MCCOG Logo" />
                <span>DCO-550 // MOONBASE</span>
            </a>
            <div class="nav-links">
                <a href="/courses/adversary-hunting/">[ HOME ]</a>
                <a href="/courses/adversary-hunting/syllabus/">[ SYLLABUS ]</a>
                <a href="/courses/adversary-hunting/calendar/">[ CALENDAR ]</a>
                <a href="/courses/adversary-hunting/slides/">[ SLIDES ]</a>
                <a href="/courses/adversary-hunting/labs/">[ LABS ]</a>
                <a href="/courses/adversary-hunting/resources/">[ REFERENCE ]</a>
            </div>

            <div style="display: flex; align-items: center; gap: 15px;">
                <div style="position: relative;">
                    <i class="fa-solid fa-search" style="position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--text-dim); font-size: 11px;"></i>
                    <input type="text" id="global-search" placeholder="SEARCH..." style="background: rgba(0,0,0,0.5); border: 1px solid var(--border); color: var(--accent-green); font-family: 'Share Tech Mono', monospace; font-size: 11px; padding: 4px 8px 4px 25px; width: 100px; outline: none; transition: width 0.3s;" onfocus="this.style.width='160px'" onblur="this.style.width='100px'">
                </div>
                <div id="progress-container" style="display: flex; flex-direction: column; align-items: flex-end;">
                    <div style="font-family: 'Share Tech Mono', monospace; font-size: 9px; color: var(--text-dim);">PROGRESS</div>
                    <div style="width: 80px; height: 3px; background: var(--border); position: relative; margin-top: 2px;">
                        <div id="progress-bar" style="width: 0%; height: 100%; background: var(--accent-green); box-shadow: 0 0 5px var(--accent-green);"></div>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <script is:inline>
        function updateGlobalProgress() {
            const completed = JSON.parse(localStorage.getItem('dco550_completed_labs')) || [];
            const totalLabs = 11; // Based on syllabus
            const percent = (completed.length / totalLabs) * 100;
            const bar = document.getElementById('progress-bar');
            if (bar) bar.style.width = `${percent}%`;
        }
        window.addEventListener('load', updateGlobalProgress);
        window.addEventListener('labCompleted', updateGlobalProgress);
    </script>

    <main>
        <slot />
    </main>

    <footer>
        <div class="container">
            <p>&copy; 2026 Iver Iverson | Advanced Adversary Hunting & Malware RE</p>
            <p style="font-family: 'Share Tech Mono', monospace; font-size: 12px; margin-top: 10px;">SYSTEM STATUS: NOMINAL</p>
        </div>
    </footer>
</body>
</html>
