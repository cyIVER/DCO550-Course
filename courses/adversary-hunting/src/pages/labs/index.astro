---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Hands-on Labs">
    <section class="hero">
        <div class="container">
            <div style="font-family: 'Share Tech Mono', monospace; color: var(--accent-green); letter-spacing: 4px; margin-bottom: 20px;">DCO 550 // TRAINING GROUNDS</div>
            <h1>Cyber Range <span class="accent">Labs</span></h1>
            <p style="font-size: 20px; color: var(--text-secondary); max-width: 800px; margin: 20px auto;">
                Step-by-step technical guides for deploying infrastructure and performing advanced adversary hunts.
            </p>
        </div>
    </section>

    <section class="container" style="padding: 60px 0;">
        <div class="card">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div style="color: var(--accent-green); font-size: 14px; font-family: 'Share Tech Mono', monospace; margin-bottom: 10px;">LAB 01 // FOUNDATION</div>
                    <h2 style="margin: 0 0 10px 0;">Azure Cyber Range Build Guide</h2>
                    <p style="color: var(--text-secondary); margin-bottom: 20px;">Deploy a multi-tier isolated VNet with forensics, malware RE, and victim systems.</p>
                    <div style="display: flex; gap: 15px;">
                        <a href="/courses/adversary-hunting/labs/azure-build-guide/" class="btn" style="margin-top: 0;">Read Guide</a>
                        <a href="/courses/adversary-hunting/labs/infrastructure/main.bicep" download style="color: var(--accent-green); text-decoration: none; font-size: 14px; align-self: center; font-weight: bold;">[ DOWNLOAD BICEP ]</a>
                    </div>
                </div>
                <div style="text-align: right;">
                    <span style="background: rgba(34, 197, 94, 0.1); color: var(--accent-green); padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: bold;">AVAILABLE</span>
                </div>
            </div>
        </div>

        <div class="card">
            <div style="display: flex; justify-content: space-between; align-items: flex-start;">
                <div>
                    <div style="color: var(--accent-blue); font-size: 14px; font-family: 'Share Tech Mono', monospace; margin-bottom: 10px;">LAB 02 // PERSISTENCE</div>
                    <h2 style="margin: 0 0 10px 0;">Hunting the Shadow Registry</h2>
                    <p style="color: var(--text-secondary); margin-bottom: 20px;">Locate and analyze hidden registry keys used for boot-time persistence.</p>
                    <div style="display: flex; gap: 15px;">
                        <a href="/courses/adversary-hunting/labs/hunting-the-shadow-registry/" class="btn" style="margin-top: 0; background-color: var(--accent-blue);">Read Guide</a>
                    </div>
                </div>
                <div style="text-align: right;">
                    <span style="background: rgba(59, 130, 246, 0.1); color: var(--accent-blue); padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: bold;">AVAILABLE</span>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
