---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="C2 Dashboard">
    <section class="hero">
        <div class="container">
            <div style="font-family: 'Share Tech Mono', monospace; color: var(--accent-gold); letter-spacing: 4px; margin-bottom: 20px;">[ INSTRUCTOR OVERRIDE // LEVEL 4 ]</div>
            <h1>C2 <span class="accent">DASHBOARD</span></h1>
            <p style="font-size: 18px; color: var(--text-secondary); max-width: 800px; margin: 20px auto;">
                Command and Control interface for Operation Adversary Hunt. Authorize mission phases and monitor system telemetry.
            </p>
        </div>
    </section>

    <section class="container" style="padding: 60px 0;">
        <div id="login-gate" class="card" style="max-width: 500px; margin: 0 auto; text-align: center; border-color: var(--accent-gold);">
            <h3 style="color: var(--accent-gold); margin-top: 0;">AUTHORIZATION REQUIRED</h3>
            <p style="color: var(--text-secondary); margin-bottom: 25px; font-size: 14px;">SYSTEM IS CURRENTLY IN READ-ONLY MODE. PROVIDE OVERRIDE CREDENTIALS TO ENABLE C2.</p>
            
            <div style="position: relative; margin-bottom: 20px;">
                <input type="password" id="password" placeholder="ENTER ACCESS CODE" style="width: 100%; padding: 15px; background: #000; border: 1px solid var(--border-bright); color: var(--accent-gold); font-family: 'Share Tech Mono', monospace; text-align: center; outline: none; transition: border-color 0.2s;">
            </div>
            
            <button id="login-btn" class="btn" style="width: 100%; border-color: var(--accent-gold); color: var(--accent-gold);">ESTABLISH UPLINK</button>
            <p id="error-msg" style="color: var(--accent-red); font-family: 'Share Tech Mono', monospace; font-size: 12px; margin-top: 15px; display: none;">[ ERROR ] UNAUTHORIZED ACCESS DETECTED</p>
        </div>

        <div id="management-panel" style="display: none;">
            <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(400px, 1fr)); gap: 40px;">
                <!-- Visibility Controls -->
                <div class="card">
                    <h3 style="color: var(--accent-green); margin-top: 0; border-bottom: 1px solid var(--border); padding-bottom: 10px; margin-bottom: 20px;">PHASE AUTHORIZATION</h3>
                    
                    <div style="display: flex; flex-direction: column; gap: 15px;">
                        <div class="control-row">
                            <div class="info">
                                <span class="label">PHASE 01 // TRIAD</span>
                                <span class="subtext">Endpoint Forensics & Static Analysis</span>
                            </div>
                            <button class="toggle-btn active" data-module="1" disabled>AUTHORIZED</button>
                        </div>
                        
                        <div class="control-row">
                            <div class="info">
                                <span class="label">PHASE 02 // PERSISTENCE</span>
                                <span class="subtext">Registry, WMI & Memory Analysis</span>
                            </div>
                            <button class="toggle-btn" data-module="2">LOADING...</button>
                        </div>
                        
                        <div class="control-row">
                            <div class="info">
                                <span class="label">PHASE 03 // AUTOMATION</span>
                                <span class="subtext">Python ETL & Statistical Models</span>
                            </div>
                            <button class="toggle-btn" data-module="3">LOADING...</button>
                        </div>
                    </div>
                </div>

                <!-- Global Overrides -->
                <div class="card">
                    <h3 style="color: var(--accent-blue); margin-top: 0; border-bottom: 1px solid var(--border); padding-bottom: 10px; margin-bottom: 20px;">SYSTEM OVERRIDES</h3>
                    
                    <div style="display: grid; grid-template-columns: 1fr; gap: 15px;">
                        <div class="override-box">
                            <div style="margin-bottom: 15px;">
                                <div style="font-weight: bold; margin-bottom: 5px;">LAB INFRASTRUCTURE RESET</div>
                                <div style="font-size: 12px; color: var(--text-secondary);">Force-revert all student Azure environments to baseline snapshots.</div>
                            </div>
                            <button class="btn" style="font-size: 12px; border-color: var(--accent-blue); color: var(--accent-blue); width: 100%;">EXECUTE RESET</button>
                        </div>

                        <div class="override-box" style="border-color: var(--accent-red); background: rgba(255, 62, 62, 0.05);">
                            <div style="margin-bottom: 15px;">
                                <div style="font-weight: bold; color: var(--accent-red); margin-bottom: 5px;">EMERGENCY SHUTDOWN</div>
                                <div style="font-size: 12px; color: var(--text-secondary);">Disable all platform access and terminate active lab sessions.</div>
                            </div>
                            <button class="btn" style="font-size: 12px; border-color: var(--accent-red); color: var(--accent-red); width: 100%;">SIGNAL SHUTDOWN</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>

<style>
    .control-row {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 15px;
        background: rgba(255, 255, 255, 0.02);
        border: 1px solid var(--border);
    }
    .control-row .info {
        display: flex;
        flex-direction: column;
    }
    .control-row .label {
        font-family: 'Share Tech Mono', monospace;
        font-weight: bold;
        font-size: 14px;
        color: var(--text-primary);
    }
    .control-row .subtext {
        font-size: 11px;
        color: var(--text-dim);
        text-transform: uppercase;
    }
    .toggle-btn {
        background: transparent;
        border: 1px solid var(--text-dim);
        color: var(--text-dim);
        padding: 8px 15px;
        cursor: pointer;
        font-family: 'Share Tech Mono', monospace;
        font-size: 11px;
        transition: all 0.2s;
    }
    .toggle-btn.active {
        border-color: var(--accent-green);
        color: var(--accent-green);
        background: rgba(0, 255, 65, 0.1);
        box-shadow: 0 0 10px rgba(0, 255, 65, 0.1);
    }
    .toggle-btn:not(:disabled):hover {
        background: rgba(255, 255, 255, 0.05);
        border-color: var(--text-primary);
    }
    .override-box {
        padding: 20px;
        border: 1px solid var(--border-bright);
        background: rgba(0, 210, 255, 0.02);
    }
    input:focus {
        border-color: var(--accent-gold) !important;
        box-shadow: 0 0 10px rgba(255, 204, 0, 0.1);
    }
</style>

<script is:inline>
    const loginGate = document.getElementById('login-gate');
    const managementPanel = document.getElementById('management-panel');
    const passwordInput = document.getElementById('password');
    const loginBtn = document.getElementById('login-btn');
    const errorMsg = document.getElementById('error-msg');

    const stateKey = 'dco550_module_state';
    let moduleState = JSON.parse(localStorage.getItem(stateKey)) || {
        '1': 'unlocked',
        '2': 'unlocked',
        '3': 'locked'
    };

    function updateUI() {
        document.querySelectorAll('.toggle-btn').forEach(btn => {
            const modId = btn.getAttribute('data-module');
            if (moduleState[modId] === 'unlocked') {
                btn.classList.add('active');
                btn.textContent = 'AUTHORIZED';
            } else {
                btn.classList.remove('active');
                btn.textContent = 'STANDBY';
            }
        });
    }

    loginBtn.addEventListener('click', () => {
        // Logic check: password is 'mccog-c2'
        if (passwordInput.value.toLowerCase() === 'mccog-c2') {
            loginGate.style.display = 'none';
            managementPanel.style.display = 'block';
            updateUI();
        } else {
            errorMsg.style.display = 'block';
            passwordInput.value = '';
            setTimeout(() => { errorMsg.style.display = 'none'; }, 3000);
        }
    });

    passwordInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') loginBtn.click();
    });

    document.querySelectorAll('.toggle-btn').forEach(btn => {
        btn.addEventListener('click', () => {
            const modId = btn.getAttribute('data-module');
            if (btn.disabled) return;

            const isCurrentlyUnlocked = moduleState[modId] === 'unlocked';
            moduleState[modId] = isCurrentlyUnlocked ? 'locked' : 'unlocked';
            localStorage.setItem(stateKey, JSON.stringify(moduleState));

            updateUI();
        });
    });
</script>
